# Robot network
# Change this value according to your Niryo Ned network setup.
NIRYO_IP=169.254.200.200

# Camera
# USB camera index may change between machines, e.g. 0, 2, or 3.
CAMERA_INDEX=3

# Default safe rollout parameters for Direct Mini-VLA
ROBOT_VELOCITY=5
MINIVLA_STEPS=40
MINIVLA_ACTION_SCALE=0.45
MINIVLA_MAX_DELTA=0.012

# Mini-VLA paths
MINIVLA_DATASET=data/niryo_push_real_v5_trim_minivla.npz
MINIVLA_DIRECT_CKPT=checkpoints/minivla_push_trim_v5_direct.pt
MINIVLA_DIFFUSION_CKPT=checkpoints/minivla_push_trim_v5.pt
